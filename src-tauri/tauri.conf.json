{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri-docs/main/v2/schema/tauri.conf.json",
  "productName": "Claude Team HUD",
  "version": "0.1.0",
  "identifier": "com.claude-team-hud.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Team HUD",
        "width": 1280,
        "height": 960,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
